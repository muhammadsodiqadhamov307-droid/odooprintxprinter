<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pos_print_agent_config_tree" model="ir.ui.view">
            <field name="name">pos.print.agent.config.tree</field>
            <field name="model">pos.print.agent.config</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="active"/>
                    <field name="poll_interval_sec"/>
                    <field name="default_mode"/>
                    <field name="default_network_ip"/>
                    <field name="default_network_port"/>
                </list>
            </field>
        </record>

        <record id="view_pos_print_agent_config_form" model="ir.ui.view">
            <field name="name">pos.print.agent.config.form</field>
            <field name="model">pos.print.agent.config</field>
            <field name="arch" type="xml">
                <form string="PoS Print Agent Configuration">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                                <field name="poll_interval_sec"/>
                            </group>
                        </group>

                        <group string="Agent Odoo Connection">
                            <group>
                                <field name="agent_odoo_url"/>
                                <field name="agent_odoo_db"/>
                            </group>
                            <group>
                                <field name="agent_odoo_username"/>
                                <field name="agent_odoo_password" password="True"/>
                            </group>
                        </group>

                        <group string="Default Route Fallback">
                            <group>
                                <field name="default_mode"/>
                                <field name="default_network_ip" invisible="default_mode != 'network'"/>
                                <field name="default_network_port" invisible="default_mode != 'network'"/>
                            </group>
                            <group>
                                <field name="default_usb_vendor_id" invisible="default_mode != 'usb'"/>
                                <field name="default_usb_product_id" invisible="default_mode != 'usb'"/>
                            </group>
                        </group>

                        <group string="Default Reliability">
                            <group>
                                <field name="default_timeout_sec"/>
                                <field name="default_retries"/>
                                <field name="default_cooldown_sec"/>
                            </group>
                        </group>

                        <group string="Printer Routes">
                            <field name="route_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="active"/>
                                    <field name="name"/>
                                    <field name="mode"/>
                                    <field name="network_ip"/>
                                    <field name="network_port"/>
                                    <field name="usb_vendor_id"/>
                                    <field name="usb_product_id"/>
                                    <field name="timeout_sec"/>
                                    <field name="retries"/>
                                    <field name="cooldown_sec"/>
                                </list>
                                <form string="Printer Route">
                                    <group>
                                        <group>
                                            <field name="sequence"/>
                                            <field name="active"/>
                                            <field name="name"/>
                                            <field name="mode"/>
                                        </group>
                                        <group>
                                            <field name="network_ip" invisible="mode != 'network'"/>
                                            <field name="network_port" invisible="mode != 'network'"/>
                                            <field name="usb_vendor_id" invisible="mode != 'usb'"/>
                                            <field name="usb_product_id" invisible="mode != 'usb'"/>
                                        </group>
                                    </group>
                                    <group string="Reliability">
                                        <field name="timeout_sec"/>
                                        <field name="retries"/>
                                        <field name="cooldown_sec"/>
                                    </group>
                                    <group>
                                        <field name="notes"/>
                                    </group>
                                </form>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pos_print_agent_route_tree" model="ir.ui.view">
            <field name="name">pos.print.agent.route.tree</field>
            <field name="model">pos.print.agent.route</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle"/>
                    <field name="active"/>
                    <field name="name"/>
                    <field name="config_id"/>
                    <field name="mode"/>
                    <field name="network_ip"/>
                    <field name="network_port"/>
                    <field name="usb_vendor_id"/>
                    <field name="usb_product_id"/>
                </list>
            </field>
        </record>

        <record id="view_pos_print_agent_route_form" model="ir.ui.view">
            <field name="name">pos.print.agent.route.form</field>
            <field name="model">pos.print.agent.route</field>
            <field name="arch" type="xml">
                <form string="PoS Print Route">
                    <sheet>
                        <group>
                            <group>
                                <field name="config_id"/>
                                <field name="sequence"/>
                                <field name="active"/>
                                <field name="name"/>
                                <field name="mode"/>
                            </group>
                            <group>
                                <field name="network_ip" invisible="mode != 'network'"/>
                                <field name="network_port" invisible="mode != 'network'"/>
                                <field name="usb_vendor_id" invisible="mode != 'usb'"/>
                                <field name="usb_product_id" invisible="mode != 'usb'"/>
                            </group>
                        </group>
                        <group string="Reliability">
                            <field name="timeout_sec"/>
                            <field name="retries"/>
                            <field name="cooldown_sec"/>
                        </group>
                        <group>
                            <field name="notes"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pos_print_job_tree" model="ir.ui.view">
            <field name="name">pos.print.job.tree</field>
            <field name="model">pos.print.job</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="state"/>
                    <field name="printer_type"/>
                    <field name="printer_name"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

        <record id="view_pos_print_job_form" model="ir.ui.view">
            <field name="name">pos.print.job.form</field>
            <field name="model">pos.print.job</field>
            <field name="arch" type="xml">
                <form string="PoS Print Job">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="state"/>
                                <field name="printer_type"/>
                                <field name="printer_name"/>
                            </group>
                            <group>
                                <field name="create_date" readonly="1"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="error_msg"/>
                        </group>
                        <group>
                            <field name="data"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_pos_print_agent_config" model="ir.actions.act_window">
            <field name="name">Agent Settings</field>
            <field name="res_model">pos.print.agent.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_pos_print_agent_route" model="ir.actions.act_window">
            <field name="name">Printer Routes</field>
            <field name="res_model">pos.print.agent.route</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_pos_print_jobs" model="ir.actions.act_window">
            <field name="name">Print Jobs</field>
            <field name="res_model">pos.print.job</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_pos_custom_print_root" name="PoS Custom Print" sequence="90"/>
        <menuitem
            id="menu_pos_custom_print_agent_settings"
            name="Agent Settings"
            parent="menu_pos_custom_print_root"
            action="action_pos_print_agent_config"
            sequence="10"/>
        <menuitem
            id="menu_pos_custom_print_routes"
            name="Printer Routes"
            parent="menu_pos_custom_print_root"
            action="action_pos_print_agent_route"
            sequence="20"/>
        <menuitem
            id="menu_pos_custom_print_jobs"
            name="Print Jobs"
            parent="menu_pos_custom_print_root"
            action="action_pos_print_jobs"
            sequence="30"/>
    </data>
</odoo>
